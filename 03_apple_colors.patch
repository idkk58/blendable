   btheme->space_properties.back[2] = 236;
   btheme->space_properties.back[3] = 255;
 
+  /* Properties sub-panel: slightly lighter */
+  btheme->space_properties.panelcolors.back[0] = 245;
+  btheme->space_properties.panelcolors.back[1] = 245;
+  btheme->space_properties.panelcolors.back[2] = 245;
+  btheme->space_properties.panelcolors.back[3] = 245;  /* slight transparency */
+
+  /* 3D Viewport background: Apple's neutral */
+  btheme->space_view3d.gradients.high_gradient[0] = 0.89f;
+  btheme->space_view3d.gradients.high_gradient[1] = 0.89f;
+  btheme->space_view3d.gradients.high_gradient[2] = 0.89f;
+
+  /* Header bar: match macOS toolbar exactly */
+  btheme->space_view3d.header[0] = 200;
+  btheme->space_view3d.header[1] = 200;
+  btheme->space_view3d.header[2] = 200;
+  btheme->space_view3d.header[3] = 255;
+
+  /* ── BLENDABLE PANEL HEADER ───────────────────────── */
+  /* Subtle separator line between panels, no heavy bar */
+  btheme->space_properties.panelcolors.header[0] = 236;
+  btheme->space_properties.panelcolors.header[1] = 236;
+  btheme->space_properties.panelcolors.header[2] = 236;
+  btheme->space_properties.panelcolors.header[3] = 255;
