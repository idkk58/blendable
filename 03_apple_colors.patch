+/* Blendable: Apple-inspired default color palette */
+/* Based on macOS Ventura light mode system colors   */
 
+/* ── BLENDABLE PALETTE ─────────────────────────────────────────────
+ * All colors are RGBA 0-255. These become Blender's startup defaults.
+ *
+ * Apple System Colors (Ventura Light):
+ *   Accent Blue:    #0A84FF  →  {10,  132, 255, 255}
+ *   Label Primary:  #000000  →  {0,   0,   0,   255}
+ *   BG Primary:     #ECECEC  →  {236, 236, 236, 255}
+ *   BG Secondary:   #F5F5F5  →  {245, 245, 245, 255}
+ *   BG Tertiary:    #FFFFFF  →  {255, 255, 255, 255}
+ *   Separator:      #C6C6C8  →  {198, 198, 200, 30 }
+ *   Fill Primary:   #787880  →  {120, 120, 128, 45 }
+ *   Fill Secondary: #787880  →  {120, 120, 128, 30 }
+ * ────────────────────────────────────────────────────────────────── */
+
+/* Helper macro: pack uchar RGBA into theme color array */
+#define BLENDABLE_COL(r, g, b, a) {(uchar)(r), (uchar)(g), (uchar)(b), (uchar)(a)}
+
 @@ -400,7 +418,7 @@ static void ui_theme_init_default_theme(bTheme *btheme)
  {
-  /* ── BUTTONS ──────────────────────────────────────── */
+  /* ── BLENDABLE BUTTONS ────────────────────────────── */
   uiWidgetColors *wcol_but = &btheme->tui.wcol_but;
-  rgba_char_args_set(wcol_but->outline,    0x19, 0x19, 0x19, 0xFF);
-  rgba_char_args_set(wcol_but->inner,      0x45, 0x45, 0x45, 0xFF);
-  rgba_char_args_set(wcol_but->inner_sel,  0x64, 0x64, 0x64, 0xFF);
-  rgba_char_args_set(wcol_but->item,       0xAC, 0xAC, 0xAC, 0xFF);
-  rgba_char_args_set(wcol_but->text,       0xFF, 0xFF, 0xFF, 0xFF);
-  rgba_char_args_set(wcol_but->text_sel,   0xFF, 0xFF, 0xFF, 0xFF);
+  /* Apple-style: light gray fill, near-invisible border, dark text */
+  rgba_char_args_set(wcol_but->outline,    0xC6, 0xC6, 0xC8, 0x55);  /* subtle border   */
+  rgba_char_args_set(wcol_but->inner,      0xF5, 0xF5, 0xF5, 0xFF);  /* off-white fill  */
+  rgba_char_args_set(wcol_but->inner_sel,  0x0A, 0x84, 0xFF, 0xFF);  /* Apple Blue sel  */
+  rgba_char_args_set(wcol_but->item,       0x0A, 0x84, 0xFF, 0xFF);  /* accent          */
+  rgba_char_args_set(wcol_but->text,       0x1C, 0x1C, 0x1E, 0xFF);  /* near-black text */
+  rgba_char_args_set(wcol_but->text_sel,   0xFF, 0xFF, 0xFF, 0xFF);  /* white on blue   */
+  wcol_but->shadetop  = 0;   /* flat — no gradient */
