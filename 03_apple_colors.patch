-  /* ── MENUS ────────────────────────────────────────── */
+  /* ── BLENDABLE MENUS ──────────────────────────────── */
   uiWidgetColors *wcol_menu = &btheme->tui.wcol_menu;
-  rgba_char_args_set(wcol_menu->inner,      0x1A, 0x1A, 0x1A, 0xFF);
