+  rgba_char_args_set(wcol_toolbar->inner,     0xEC, 0xEC, 0xEC, 0xFF);
+  rgba_char_args_set(wcol_toolbar->outline,   0xC6, 0xC6, 0xC8, 0x40);
+  rgba_char_args_set(wcol_toolbar->text,      0x1C, 0x1C, 0x1E, 0xFF);
